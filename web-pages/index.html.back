<!doctype html>
<html lang="es-MX">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Pagos Recurrentes: asistente para recordar pagos de servicios, colegiaturas, seguros y obligaciones periódicas." />
  <title>Pagos Recurrentes</title>
  <style>
    :root {
      --paper: #f2f2f2;
      --ink: #0a0a0a;
      --muted: #666666;
      --blue: #0057ff;
      --white: #ffffff;
      --rule-light: rgba(10, 10, 10, 0.10);
      --rule-dark: rgba(255, 255, 255, 0.20);
      --font-heading: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --font-body: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --font-serif: Georgia, "Times New Roman", serif;
    }

    * { box-sizing: border-box; }

    html {
      min-height: 100%;
      scroll-behavior: smooth;
      background: var(--paper);
    }

    body {
      margin: 0;
      min-height: 100%;
      background: var(--paper);
      color: var(--ink);
      font-family: var(--font-body);
      text-rendering: optimizeLegibility;
      -webkit-font-smoothing: antialiased;
    }

    img { max-width: 100%; display: block; }

    .page {
      min-height: 100vh;
      overflow-x: hidden;
    }

    .kinetic-pulse {
      position: fixed;
      z-index: 50;
      width: 20px;
      height: 20px;
      left: -100px;
      top: -100px;
      border-radius: 999px;
      pointer-events: none;
      background: radial-gradient(circle, rgba(0,87,255,0.5) 0%, rgba(0,87,255,0) 70%);
      box-shadow: 0 0 20px 8px rgba(0,87,255,0.15);
      transition: left 0.08s ease-out, top 0.08s ease-out;
    }

    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 6vw;
      overflow: hidden;
    }

    .hero::before,
    .hero::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      height: 1px;
      background: var(--rule-light);
    }

    .hero::before { top: 0; }
    .hero::after { bottom: 0; }

    .questions {
      display: flex;
      flex-direction: column;
      gap: clamp(4rem, 8vw, 6rem);
      max-width: 72rem;
      width: 100%;
    }

    .question {
      max-width: 48rem;
      opacity: 0;
      transform: translateY(40px);
      animation: reveal 0.8s ease-out forwards;
      will-change: transform;
    }

    .question:nth-child(1) { align-self: flex-start; text-align: left; animation-delay: 0.30s; }
    .question:nth-child(2) { align-self: center; text-align: right; animation-delay: 0.55s; }
    .question:nth-child(3) { align-self: flex-start; margin-left: min(4rem, 8vw); text-align: left; animation-delay: 0.80s; }

    .question p {
      margin: 0;
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(2rem, 7vw, 4.5rem);
      line-height: 1.1;
      letter-spacing: -0.03em;
    }

    .solution {
      position: relative;
      overflow: hidden;
      background: var(--ink);
      color: var(--white);
      padding: clamp(6rem, 12vw, 8rem) 6vw;
    }

    .solution-bg {
      position: absolute;
      inset: 0;
      opacity: 0.10;
      pointer-events: none;
    }

    .solution-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .solution-content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .app-title {
      margin: 0 0 4rem;
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(3rem, 10vw, 6rem);
      line-height: 0.95;
      letter-spacing: -0.05em;
      color: transparent;
      -webkit-text-stroke: 1.5px rgba(255,255,255,0.70);
      text-stroke: 1.5px rgba(255,255,255,0.70);
    }

    .blue-rule {
      width: 6rem;
      height: 1px;
      background: var(--blue);
      margin-bottom: 4rem;
    }

    .description {
      max-width: 42rem;
      margin: 0;
      color: rgba(255,255,255,0.90);
      font-size: clamp(1rem, 2vw, 1.25rem);
      line-height: 1.6;
    }

    .description strong,
    .description .brand {
      color: var(--blue);
      font-weight: 700;
    }

    .description em {
      font-style: italic;
      font-weight: 700;
      color: var(--white);
    }

    .disclaimer {
      margin-top: clamp(4rem, 8vw, 6rem);
      max-width: 36rem;
      border: 1px solid var(--rule-dark);
      border-radius: 2px;
      padding: 1rem clamp(1.5rem, 4vw, 2.5rem);
    }

    .disclaimer p {
      margin: 0;
      color: rgba(255,255,255,0.50);
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: clamp(0.75rem, 1.5vw, 0.875rem);
      line-height: 1.5;
    }

    .footer {
      background: var(--paper);
      padding: clamp(3rem, 6vw, 4rem) 6vw;
    }

    .footer-rule {
      width: 100%;
      height: 1px;
      background: var(--rule-light);
      margin-bottom: 2.5rem;
    }

    .footer-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    .mission {
      margin: 0;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.10em;
      font-size: 0.75rem;
      flex-shrink: 0;
    }

    .logo-wrap {
      flex: 1;
      display: flex;
      justify-content: center;
      width: 100%;
    }

    .logo {
      height: clamp(3rem, 6vw, 3.5rem);
      object-fit: contain;
    }

    .footer-spacer { display: none; }

    .reveal-on-scroll {
      opacity: 0;
      transform: translateY(30px) scale(0.98);
      transition: opacity 0.8s ease-out, transform 0.8s ease-out;
    }

    .reveal-on-scroll.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    @keyframes reveal {
      to { opacity: 1; transform: translateY(0); }
    }

    @media (min-width: 768px) {
      .hero, .solution, .footer { padding-left: 8vw; padding-right: 8vw; }
      .footer-row { flex-direction: row; gap: 3rem; }
      .footer-spacer { display: block; flex-shrink: 0; width: 180px; }
    }

    @media (max-width: 767px) {
      .question:nth-child(3) { margin-left: 1rem; }
      .kinetic-pulse { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      *, *::before, *::after {
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important;
      }
      .question, .reveal-on-scroll { opacity: 1; transform: none; }
      .kinetic-pulse { display: none; }
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="kinetic-pulse" aria-hidden="true"></div>

    <section class="hero" aria-label="Preguntas frecuentes sobre pagos recurrentes">
      <div class="questions">
        <article class="question" data-speed="0.3">
          <p>¿Te cortaron la luz porque se te olvidó pagarla a tiempo?</p>
        </article>
        <article class="question" data-speed="0.5">
          <p>¿Cuánto he pagado de servicios del departamento?</p>
        </article>
        <article class="question" data-speed="0.7">
          <p>¿Cuánto debo pagar de servicios y colegiaturas el próximo mes?</p>
        </article>
      </div>
    </section>

    <section class="solution" aria-label="Presentación de Pagos Recurrentes">
      <div class="solution-bg" aria-hidden="true">
        <img src="https://media.base44.com/images/public/6a498c433cf75524f9bb0ec5/c6b0d2402_generated_24b0691f.png" alt="" />
      </div>

      <div class="solution-content">
        <h1 class="app-title reveal-on-scroll">Pagos Recurrentes</h1>
        <div class="blue-rule reveal-on-scroll" aria-hidden="true"></div>

        <p class="description reveal-on-scroll">
          Si estas y dudas similares no te dejan dormir,
          <span class="brand">“Pagos Recurrentes”</span>
          es una app intuitiva y fácil de usar que te permite gestionar ágilmente y desde tu celular o computadora tus pagos de gobierno, de colegiaturas, de seguros, de servicios y similares para que tengas control perfecto de los mismos y nunca más te pase
          <em>“¡Se me olvidó pagar!”</em>.
        </p>

        <div class="disclaimer reveal-on-scroll">
          <p>Nota: La app no gestiona los pagos, solo es un asistente que nunca olvida.</p>
        </div>
      </div>
    </section>

    <footer class="footer" aria-label="Astrogato Labs">
      <div class="footer-rule" aria-hidden="true"></div>
      <div class="footer-row">
        <p class="mission">Una misión en progreso de:</p>
        <div class="logo-wrap">
          <img class="logo" src="https://media.base44.com/images/public/user_69043ee0497ca0e62441bd8e/bb0660ebb_astrogato-textoderechacentrado.png" alt="Astrogato Labs" />
        </div>
        <div class="footer-spacer" aria-hidden="true"></div>
      </div>
    </footer>
  </main>

  <script>
    (function () {
      var reducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reducedMotion) {
        var pulse = document.querySelector('.kinetic-pulse');
        window.addEventListener('mousemove', function (event) {
          if (!pulse) return;
          pulse.style.left = (event.clientX - 10) + 'px';
          pulse.style.top = (event.clientY - 10) + 'px';
        }, { passive: true });

        var questions = Array.prototype.slice.call(document.querySelectorAll('.question'));
        window.addEventListener('scroll', function () {
          var y = window.scrollY || window.pageYOffset || 0;
          questions.forEach(function (item) {
            var speed = parseFloat(item.getAttribute('data-speed') || '0');
            item.style.transform = 'translateY(' + (-Math.min(y, 800) * 0.15 * speed) + 'px)';
          });
        }, { passive: true });
      }

      var revealItems = document.querySelectorAll('.reveal-on-scroll');
      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -80px 0px' });

        revealItems.forEach(function (item) { observer.observe(item); });
      } else {
        revealItems.forEach(function (item) { item.classList.add('visible'); });
      }
    })();
  </script>
</body>
</html>
